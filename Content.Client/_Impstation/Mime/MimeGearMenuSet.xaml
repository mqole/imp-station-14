<Control xmlns="https://spacestation14.io"
         xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
         xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client">
    <!-- Name and button -->
    <PanelContainer Margin="10 5 10 20">
        <PanelContainer.PanelOverride>
            <gfx:StyleBoxFlat BackgroundColor="#1c1c23" />
        </PanelContainer.PanelOverride>
        <BoxContainer Orientation="Vertical" HorizontalExpand="True">
            <GridContainer Columns="2" MinSize="600 0">
                <Button Margin="0 0" Name="SetButton" Text="Select" StyleClasses="OpenRight" Access="Public" HorizontalAlignment="Right"/>
                <Label Name="SetName" Text="Set"></Label>
            </GridContainer>
            <!-- Icon and Description -->
            <GridContainer Columns="2">
                <TextureRect Name="Icon" Margin="5" Stretch="KeepAspectCentered"
                             VerticalAlignment="Center" HorizontalAlignment="Right" SetSize="76 76"/>
                <Label Name="SetDescription" Text="Description" StyleClasses="StatusFieldTitle"></Label>
            </GridContainer>
        </BoxContainer>
    </PanelContainer>
</Control>
